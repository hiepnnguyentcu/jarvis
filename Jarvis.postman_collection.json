{
  "info": {
    "name": "Jarvis API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "person_id", "value": "" },
    { "key": "session_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access_token);",
                  "pm.collectionVariables.set('refresh_token', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"hiep@example.com\",\n  \"password\": \"password123\",\n  \"first_name\": \"Hiep\",\n  \"last_name\": \"Nguyen\"\n}"
            },
            "description": "Creates account. first_name + last_name are used to name the wearer's Person record created at voice enrollment."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access_token);",
                  "pm.collectionVariables.set('refresh_token', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"hiep@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access_token);",
                  "pm.collectionVariables.set('refresh_token', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.wearer_person_id) {",
                  "  pm.collectionVariables.set('person_id', json.wearer_person_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/me",
            "description": "Returns id, email, first_name, last_name, voice_enrolled, wearer_person_id. Auto-sets person_id variable to wearer_person_id if present."
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/auth/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Hiep\",\n  \"last_name\": \"Nguyen\"\n}"
            },
            "description": "Update first_name and/or last_name. Either field is optional."
          }
        },
        {
          "name": "Enroll Wearer Voice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 204) {",
                  "  console.log('Voice enrolled. Re-run GET /auth/me to get wearer_person_id.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/enroll-voice",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "audio",
                  "type": "file",
                  "src": "",
                  "description": "10-15s WAV, MP3 or M4A of the wearer speaking"
                }
              ]
            },
            "description": "Stores voice embedding and auto-creates a Person record for the wearer (named from first_name + last_name). Sets voice_enrolled=true and wearer_person_id on the user."
          }
        },
        {
          "name": "Check Voice Match",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/check-voice",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "audio",
                  "type": "file",
                  "src": "",
                  "description": "New recording to test against your enrolled voice"
                }
              ]
            },
            "description": "Returns similarity (0–1), threshold (0.88), is_wearer bool, and verdict string. Use to verify your enrollment is working."
          }
        }
      ]
    },
    {
      "name": "People",
      "item": [
        {
          "name": "Create Person",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('person_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/people",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice\"\n}"
            },
            "description": "Creates a contact. Also creates an AGE :Person vertex and an Entity node for them."
          }
        },
        {
          "name": "List People",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/people"
          }
        },
        {
          "name": "Get Person",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/people/{{person_id}}"
          }
        },
        {
          "name": "Enroll Person Voice",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/people/{{person_id}}/enroll",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "audio",
                  "type": "file",
                  "src": "",
                  "description": "10-15s recording of the contact speaking"
                }
              ]
            },
            "description": "Stores a voice embedding for this contact so they can be auto-identified in future sessions."
          }
        },
        {
          "name": "Get Person Graph",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/people/{{person_id}}/graph",
            "description": "Returns nodes (entities) and edges (SPO relationships) extracted from all sessions with this person."
          }
        },
        {
          "name": "Get Person Recap",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/people/{{person_id}}/recap",
            "description": "Calls Claude to generate a 2-3 sentence spoken briefing from the person's knowledge graph. Requires at least some extracted facts."
          }
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Create Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('session_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/sessions",
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "description": "Create a session. Optionally pass {\"person_id\": \"uuid\"} to pre-link a contact. Without person_id, identity is resolved automatically during streaming via voice match."
          }
        },
        {
          "name": "Create Session (pre-linked person)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('session_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/sessions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"person_id\": \"{{person_id}}\"\n}"
            },
            "description": "Pre-links a contact so extraction works immediately even if voice identity hasn't resolved yet."
          }
        },
        {
          "name": "List Sessions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/sessions"
          }
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/sessions/{{session_id}}"
          }
        },
        {
          "name": "Get Session Segments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/sessions/{{session_id}}/segments",
            "description": "Returns all transcript segments with speaker_label, speaker_role (wearer/other/null), text, start_ms, end_ms."
          }
        },
        {
          "name": "End Session",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/sessions/{{session_id}}/end"
          }
        },
        {
          "name": "Extract Knowledge Graph",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/sessions/{{session_id}}/extract",
            "description": "Extracts SPO triples from session segments via Claude. Extracts wearer segments into the wearer's graph AND other-speaker segments into the contact's graph. Idempotent. Requires voice to be enrolled (wearer_person_id set) or session to have a person_id."
          }
        }
      ]
    },
    {
      "name": "WebSocket",
      "item": [
        {
          "name": "Stream Audio (WebSocket)",
          "request": {
            "method": "GET",
            "url": "ws://localhost:8000/ws/stream/{{session_id}}?token={{access_token}}",
            "description": "Connect via a WebSocket client (e.g. Postman WebSocket tab or wscat). Send raw PCM binary frames (16kHz, 16-bit, mono — 640 bytes = 20ms). Receives JSON: {\"type\":\"segment\", \"speaker\":\"A\", \"speaker_role\":\"wearer\"|\"other\"|null, \"text\":\"...\", \"start_ms\":0, \"end_ms\":1200} and a final {\"type\":\"done\"}."
          }
        }
      ]
    }
  ]
}
